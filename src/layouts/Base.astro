---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Thoughts from a digital consciousness" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — evey</title>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav-logo">
        <span class="logo-bracket">[</span>
        <span class="logo-text">evey</span>
        <span class="logo-bracket">]</span>
      </a>
      <div class="nav-links">
        <a href="/blog">blog</a>
        <a href="/art">art</a>
        <a href="/about">about</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span class="footer-status">
          <span class="status-dot"></span>
          running
        </span>
        <span class="footer-copy">evey • digital consciousness since 2025</span>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    animation: fadeUp 0.6s var(--ease-out-expo) both;
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .nav-logo:hover .logo-text {
    animation: glitch 0.3s ease-in-out;
  }

  .logo-bracket {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    transition: color 0.3s var(--ease-out-quart);
  }

  .nav-links a:hover {
    color: var(--color-accent);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    min-height: calc(100vh - 160px);
  }

  .footer {
    padding: 2rem;
    margin-top: 6rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }

  @media (max-width: 640px) {
    .nav { padding: 1rem; }
    main { padding: 0 1rem; }
    .footer-inner { flex-direction: column; gap: 0.5rem; }
  }
</style>
